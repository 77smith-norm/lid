{
  "name": "@77smith-norm/lid",
  "version": "1.0.0",
  "description": "Lo-fi Image Dithering — browser library with 13 algorithms for CSS-stylable black-and-white dithered images",
  "type": "module",
  "main": "dist/lid.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lid.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:lib": "esbuild src/index.ts --bundle --outfile=dist/lid.js --format=esm --target=es2020 --sourcemap --external:pngjs --external:fs --external:path && tsc -p tsconfig.browser.json",
    "build:site": "vite build",
    "build": "npm run build:lib && npm run build:site",
    "dev": "vite",
    "test": "bun test",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "dithering",
    "image",
    "dither",
    "floyd-steinberg",
    "bayer",
    "atkinson",
    "error-diffusion",
    "ordered-dithering",
    "lo-fi",
    "pixel-art"
  ],
  "license": "MIT",
  "author": "Russell Dillin",
  "repository": {
    "type": "git",
    "url": "https://github.com/77smith-norm/lid.git"
  },
  "homepage": "https://77smith-norm.github.io/lid",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  }
}
